# Copy this file to .env.production (or set these in your hosting provider's
# dashboard, e.g. Vercel/Netlify project settings) before building for deployment.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# Your deployed Django backend's API root. Must include /api and use https
# in production (mixed content over http will be blocked by the browser).
VITE_API_BASE_URL=https://api.yourapp.com/api

# Must match the backend's ADMIN_URL env var (minus slashes) if you customize it.
# Defaults to 'admin' to match Django's default admin path.
VITE_ADMIN_PATH=admin
