# Copy this file to .env and fill in the values you need.
# .env is gitignored — never commit real secrets.
#
#   cp .env.example .env        (macOS/Linux)
#   Copy-Item .env.example .env (Windows PowerShell)

# --- Required ---
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# --- Database ---
# Omit to use SQLite locally. Set for PostgreSQL (production/CI).
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# --- Rate limiting ---
# Defaults to True outside test runs, False during `manage.py test`.
# Uncomment to force a value (e.g. disable while load-testing locally).
# RATELIMIT_ENABLE=True

# --- Admin site ---
# Change the admin URL path from the default 'admin/' for a bit of
# security-through-obscurity.
# ADMIN_URL=admin/

# --- Email (welcome emails, error-alert emails to ADMINS) ---
# Defaults to Django's SMTP backend pointed at Gmail; leave EMAIL_HOST_USER/
# PASSWORD blank to no-op email sending in dev.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=Airport Ops <noreply@airportops.com>

# Set to receive an email whenever a production error is logged.
# ADMIN_EMAIL=
# SERVER_EMAIL=

# --- Weather (used by ai_module for live flight-delay predictions) ---
OPENWEATHER_API_KEY=

# --- LLM-backed AI chatbot (ai_module/llm_engine.py, gemini_engine.py) ---
# If neither key is set (or both fail at request time), the chatbot falls
# back to the offline rule-based engine (ai_module/chatbot.py).
# If both are set, Claude is tried first, then Gemini.
ANTHROPIC_API_KEY=
AI_CHAT_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
