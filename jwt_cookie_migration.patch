+        response = self.client.post(
+            '/api/accounts/logout/', HTTP_X_CSRFTOKEN=csrf_token)
+        self.assertEqual(response.status_code, status.HTTP_200_OK)
+        # Cookie should now be cleared (empty value / expired).
