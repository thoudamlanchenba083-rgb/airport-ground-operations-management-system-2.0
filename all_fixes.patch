+# Copy this file to .env in the backend/ directory for local dev, or set
+# these as real environment variables in your hosting provider's dashboard
+# for production (Render/Railway/Heroku-style env var settings).
+
+# --- Core (required) ---
+# Generate a real one for production: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
+SECRET_KEY=change-me-to-a-real-random-secret-key
+DEBUG=False
+ALLOWED_HOSTS=yourapp.com,www.yourapp.com
+
+# --- Database ---
+# Leave unset to fall back to local SQLite. Set to a real Postgres URL in production.
+DATABASE_URL=postgres://user:password@host:5432/dbname
+
+# --- CORS / CSRF (frontend origin) ---
+# Exact scheme + domain, no trailing slash, no wildcard.
+CORS_ALLOWED_ORIGINS=https://yourapp.com
+# Optional - defaults to CORS_ALLOWED_ORIGINS if unset. Only needed if your
+# admin panel is served from a different origin than your API.
+CSRF_TRUSTED_ORIGINS=https://yourapp.com
+
+# --- Admin path (optional) ---
+# Must end with a trailing slash. Set the matching VITE_ADMIN_PATH in the
+# frontend's env if you customize this.
+ADMIN_URL=admin/
+
+# --- Email (used for password resets, mail_admins error alerts, etc.) ---
+EMAIL_HOST=smtp.gmail.com
+EMAIL_PORT=587
+EMAIL_USE_TLS=True
+EMAIL_HOST_USER=
+EMAIL_HOST_PASSWORD=
+DEFAULT_FROM_EMAIL=Airport Ops <noreply@airportops.com>
+# Set to get emailed on unhandled server errors (django.request logger).
+ADMIN_EMAIL=
+
+# --- Third-party API keys (all optional, features degrade gracefully if unset) ---
+OPENWEATHER_API_KEY=
+ANTHROPIC_API_KEY=
+AI_CHAT_MODEL=claude-sonnet-4-6
+GEMINI_API_KEY=
+GEMINI_CHAT_MODEL=gemini-2.5-flash
